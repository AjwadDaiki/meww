{
  "name": "meowreel",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "seed:categories": "pnpm --filter @meowreel/web exec tsx scripts/seed-categories.ts",
    "generate:assets": "pnpm --filter @meowreel/web exec tsx ../../scripts/generate-assets.ts"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
